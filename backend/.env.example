NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/saas-app
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d
# Password reset (forgot password flow)
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_TOKEN_EXPIRES_IN=15m
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SmartEdge® VIP — 3 Stripe product IDs
STRIPE_SMARTEDGE_WEEKLY_PRODUCT_ID=prod_xxx
STRIPE_SMARTEDGE_MONTHLY_STANDARD_PRODUCT_ID=prod_xxx
STRIPE_SMARTEDGE_MONTHLY_VIP_PRODUCT_ID=prod_xxx

# Jonah handicapper — 3 Stripe product IDs
STRIPE_JONAH_WEEKLY_PRODUCT_ID=prod_xxx
STRIPE_JONAH_MONTHLY_STANDARD_PRODUCT_ID=prod_xxx
STRIPE_JONAH_MONTHLY_VIP_PRODUCT_ID=prod_xxx

# Optional: defaults for `npm run create:handicapper`
# HANDICAPPER_EMAIL=jonah@example.com
# HANDICAPPER_PASSWORD=change-me-8chars
# HANDICAPPER_NAME=Jonah
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@yourdomain.com
APP_NAME=SmartEdgePicks
# Comma-separated allowed frontend origins (first URL is used for Stripe redirects / emails)
FRONTEND_URL=http://localhost:3000,https://revamp-smart-edge-website.vercel.app

# Optional: public API URL for OpenAPI / Swagger "Servers" (defaults to http://localhost:PORT)
# API_PUBLIC_URL=https://api.yourdomain.com

# Parlay API — NFL odds proxy (https://parlay-api.com). In development, sandbox data is used when unset.
# PARLAY_API_KEY=your_parlay_api_key

# Telnyx SMS — outbound picks alerts (admin test + broadcast)
# Use the number from Telnyx → Numbers → My Numbers (E.164, include +1).
TELNYX_API_KEY=KEYxxxxxxxx
TELNYX_FROM_NUMBER=+15055551234
# Assign that number to this profile in Telnyx → Messaging → Messaging Profiles
TELNYX_MESSAGING_PROFILE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BULK_SMS_DELAY_MS=1500

# User flags (set in MongoDB on `users` collection, not in .env):
# isSuperAdmin — only POST /api/admin/admins (creates sub-admins)
# isAdmin — GET/PUT/DELETE /api/admin/admins
